@model IEnumerable<EncuestasApp.Models.Encuesta>

<section class="section">
    <div class="container">
        <h1 class="title has-text-light">Encuestas disponibles</h1>

        <p>
            <a asp-action="Create" class="button is-primary">Crear nueva encuesta</a>
        </p>

        <table class="table is-striped is-fullwidth has-background-dark has-text-light">
            <thead>
                <tr>
                    <th>Título</th>
                    <th>Opciones</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var encuesta in Model)
            {
                <tr>
                    <td>@encuesta.Titulo</td>
                    <td>@encuesta.Opciones.Count</td>
                    <td>
                        <a asp-action="Votar" asp-route-id="@encuesta.Id" class="button is-success">Votar</a>
                        <a asp-action="Resultados" asp-route-id="@encuesta.Id" class="button is-info">Resultados</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</section>