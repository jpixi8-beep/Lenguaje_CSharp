@model IEnumerable<MiniEcommerce.Models.CartItem>

@{
    ViewData["Title"] = "Carrito de Compras";
}

<h2>Carrito de Compras</h2>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Producto</th>
            <th>Precio</th>
            <th>Cantidad</th>
            <th>Subtotal</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model)
{
        <tr>
            <td>@item.Product.Name</td>
            <td>@item.Product.Price</td>
            <td>@item.Quantity</td>
            <td>@(item.Product.Price * item.Quantity)</td>
            <td>
                <a asp-action="Remove" asp-route-id="@item.Id" class="btn btn-danger">Eliminar</a>
            </td>
        </tr>
}
    </tbody>
</table>

<h3>Total: @ViewBag.Total</h3>

<a asp-controller="Products" asp-action="Index" class="btn btn-secondary">Seguir comprando</a>
<a asp-controller="Orders" asp-action="Create" class="btn btn-success">Finalizar compra</a>