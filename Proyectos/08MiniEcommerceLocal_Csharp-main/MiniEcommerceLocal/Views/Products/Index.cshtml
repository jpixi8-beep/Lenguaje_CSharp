@model IEnumerable<MiniEcommerce.Models.Product>

@{
    ViewData["Title"] = "Lista de Productos";
}

<h2>Productos</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Agregar Producto</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Precio</th>
            <th>Stock</th>
            <th>Imagen</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Name</td>
                <td>@item.Price</td>
                <td>@item.Stock</td>
                <td>
                    <img src="@item.ImageUrl" alt="Imagen" width="80" />
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning">Editar</a> |
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger">Eliminar</a> |
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-success">Agregar al carrito</a> |
                    <a asp-controller="Products" asp-action="Details" asp-route-id="@item.Id" class="btn btn-info">Detalles</a>
                </td>

            </tr>
        }
    </tbody>
</table>